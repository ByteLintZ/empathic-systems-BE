# AI Chatbot Platform - Environment Configuration
# Copy this file to .env and fill in your actual values

# Environment setting (development/production)
ENVIRONMENT=production

# GROQ API Configuration
GROQ_API_KEY=your_groq_api_key_here

# Server configuration (for development only - cPanel handles this in production)
HOST=0.0.0.0
PORT=8000
DEBUG=False

# Frontend URL for CORS (your actual domain for production)
FRONTEND_URL=https://yourdomain.com

# Additional CORS origins (comma-separated)
EXTRA_CORS_ORIGINS=https://www.yourdomain.com,https://subdomain.yourdomain.com

# Logging configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Rate limiting settings
RATE_LIMIT_REQUESTS_PER_DAY=3
RATE_LIMIT_WINDOW_MINUTES=1440

# API Configuration
MAX_TOKENS=1500
DEFAULT_TEMPERATURE=0.7

# Storage paths
CONVERSATIONS_DIR=data/conversations
LOGS_DIR=logs

# cPanel specific settings
APP_ROOT=/public_html/ai-chatbot-backend